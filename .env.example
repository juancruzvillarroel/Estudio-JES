# Copiá este archivo a .env y completá los valores reales (nunca subas .env al repo).

# Cadena de conexión a la base Postgres de Neon (Dashboard de Neon > Connection string, con pooler)
DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require&channel_binding=require"

# Clave secreta para firmar las cookies de sesión (generar una larga y aleatoria, ej: openssl rand -hex 32)
SESSION_SECRET=""

# Token de Vercel Blob para subir archivos (remitos, imágenes de proyecto, etc.)
# Se obtiene creando un Blob Store en el proyecto de Vercel: Storage > Create Database > Blob
BLOB_READ_WRITE_TOKEN=""

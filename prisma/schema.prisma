generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EstadoProyecto {
  ACTIVO
  PAUSADO
  FINALIZADO
}

enum EstadoPedido {
  PENDIENTE
  PARCIAL
  COMPLETO
  CANCELADO
}

enum TipoAcopio {
  MONTO
  MATERIAL
}

enum TipoMovimientoInventario {
  ENTRADA
  SALIDA
}

enum TramiteCategoria {
  ADMINISTRACION
  DEMOLICION
  OBRA
}

enum EstadoTramiteMunicipal {
  PENDIENTE
  PRESENTADO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nombre       String
  esAdmin      Boolean  @default(false)
  // Claves de las secciones (ver src/lib/paginas.ts) a las que este usuario
  // tiene acceso. Los administradores (esAdmin) siempre tienen acceso a todo,
  // sin importar este campo.
  paginasPermitidas String[] @default([])
  createdAt    DateTime @default(now())

  pedidosCreados   Pedido[]  @relation("PedidoCreadoPor")
  entregasCargadas Entrega[] @relation("EntregaRegistradaPor")
}

model Proyecto {
  id          String         @id @default(cuid())
  nombre      String
  barrio      String?
  direccion   String?
  estado      EstadoProyecto @default(ACTIVO)
  descripcion String?
  imagenUrl   String?
  // Pisos por encima de planta baja. Se usa para generar automáticamente un
  // documento (plano) por piso en las categorías de Documentación marcadas
  // como "por piso" (ver DocumentoCategoria.porPiso).
  cantidadPisos Int          @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  pedidos Pedido[]
  acopios Acopio[]
  tramitesMunicipales TramiteMunicipal[]
  documentos          Documento[]
  // Tipos de documento generados automáticamente para este proyecto (planos
  // por piso). Ver DocumentoTipo.proyectoId.
  documentoTiposPorPiso DocumentoTipo[] @relation("DocumentoTipoProyecto")
}

// Catálogo de documentos/trámites requeridos por categoría (y, dentro de
// "Obra", por etapa). Se carga con un script (prisma/seed-tramites o
// scripts/seed-tramites-municipales.ts) y se puede ampliar más adelante
// agregando filas nuevas, sin tocar código.
model TramiteMunicipalTipo {
  id          String           @id @default(cuid())
  categoria   TramiteCategoria
  // Agrupa varios tipos dentro de una categoría (ej. "Inicio" en Obra).
  // Vacío ("") si la categoría no se subdivide en etapas.
  etapa       String           @default("")
  nombre      String
  // Texto de ayuda/instrucciones para quien carga el trámite.
  descripcion String?
  orden       Int              @default(0)
  activo      Boolean          @default(true)
  createdAt   DateTime         @default(now())

  tramites TramiteMunicipal[]

  @@unique([categoria, etapa, nombre])
  @@index([categoria])
}

// Instancia por proyecto de cada tipo de trámite del catálogo: se crea la
// primera vez que alguien marca el estado, adjunta un archivo o escribe una
// nota para ese trámite en ese proyecto.
model TramiteMunicipal {
  id         String                 @id @default(cuid())
  proyectoId String
  proyecto   Proyecto               @relation(fields: [proyectoId], references: [id])
  tipoId     String
  tipo       TramiteMunicipalTipo   @relation(fields: [tipoId], references: [id])
  // Se actualiza automáticamente: PRESENTADO al adjuntar el archivo,
  // PENDIENTE si se lo quita. No se edita a mano.
  estado     EstadoTramiteMunicipal @default(PENDIENTE)
  notas      String?
  // Un solo archivo por trámite (subir uno nuevo reemplaza al anterior).
  archivoNombre String?
  archivoUrl    String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([proyectoId, tipoId])
  @@index([proyectoId])
}

enum EstadoDocumento {
  PENDIENTE
  PRESENTADO
}

// Catálogo de categorías de la pestaña "Documentación" (a diferencia de
// Municipal, acá las categorías no son un enum fijo: se crean y eliminan
// libremente desde la UI, sin tocar código).
model DocumentoCategoria {
  id        String   @id @default(cuid())
  nombre    String   @unique
  orden     Int      @default(0)
  activo    Boolean  @default(true)
  // Si es true, esta categoría no tiene un catálogo de tipos compartido:
  // en cada proyecto se genera automáticamente un tipo de documento por
  // piso ("Planta baja", "Piso 1", ...) según Proyecto.cantidadPisos (ver
  // sincronizarDocumentosPorPiso en src/actions/documentos.ts).
  porPiso   Boolean  @default(false)
  // Si tiene valor (ej. "S/"), los planos por piso de esta categoría se
  // nombran con ese prefijo + el código corto del piso (S/PB, S/1°, ...,
  // S/Azotea) en vez del nombre largo (Planta baja, Piso 1, ...).
  prefijoPiso String?
  // Si tiene elementos (ej. instalaciones: sanitaria, gas, ...), cada
  // elemento se convierte en una subsección propia (DocumentoTipo.subSeccion)
  // con un documento por piso adentro, en vez de un solo documento por piso.
  subTipos    String[] @default([])
  createdAt DateTime @default(now())

  tipos DocumentoTipo[]
}

// Catálogo de tipos de documento dentro de una categoría. Los tipos
// "globales" (proyectoId null) se crean y eliminan libremente desde la UI
// (ver src/actions/documentos.ts) y son compartidos por todos los
// proyectos. Los tipos con proyectoId asignado son generados
// automáticamente para ese proyecto puntual (categorías "por piso").
model DocumentoTipo {
  id          String             @id @default(cuid())
  categoriaId String
  categoria   DocumentoCategoria @relation(fields: [categoriaId], references: [id])
  // Null = tipo global (compartido). Con valor = generado para ese
  // proyecto puntual (planos por piso).
  proyectoId  String?
  proyecto    Proyecto?          @relation("DocumentoTipoProyecto", fields: [proyectoId], references: [id])
  nombre      String
  descripcion String?
  // Si tiene valor, agrupa este tipo dentro de una subsección dentro de su
  // categoría (ej. "Instalación sanitaria" dentro de "Instalaciones"), cada
  // una con su propio acordeón y barra de progreso. Null si la categoría no
  // se subdivide.
  subSeccion  String?
  orden       Int                @default(0)
  activo      Boolean            @default(true)
  // Si es true, el usuario lo eliminó a mano para este proyecto puntual:
  // sincronizarDocumentosPorPiso no lo vuelve a crear/reactivar aunque siga
  // en la lista de pisos/sub-tipos esperada (evita "resucitar" algo que se
  // borró a propósito la próxima vez que se guarda el proyecto).
  excluido    Boolean            @default(false)
  createdAt   DateTime           @default(now())

  documentos Documento[]

  @@unique([categoriaId, proyectoId, subSeccion, nombre])
  @@index([categoriaId])
  @@index([proyectoId])
}

// Instancia por proyecto de cada tipo de documento del catálogo: se crea la
// primera vez que alguien adjunta un archivo o escribe una nota para ese
// documento en ese proyecto.
model Documento {
  id         String          @id @default(cuid())
  proyectoId String
  proyecto   Proyecto        @relation(fields: [proyectoId], references: [id])
  tipoId     String
  tipo       DocumentoTipo   @relation(fields: [tipoId], references: [id])
  // Se actualiza automáticamente: PRESENTADO al adjuntar el archivo,
  // PENDIENTE si se lo quita. No se edita a mano.
  estado     EstadoDocumento @default(PENDIENTE)
  notas      String?
  // Un solo archivo por documento (subir uno nuevo reemplaza al anterior).
  archivoNombre String?
  archivoUrl    String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([proyectoId, tipoId])
  @@index([proyectoId])
}

model Proveedor {
  id        String   @id @default(cuid())
  // Código corto para identificar al proveedor (ej. PROV-0001).
  // Se genera automáticamente al crearlo y se puede editar después.
  codigo    String   @unique
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  cuit      String?
  notas     String?
  createdAt DateTime @default(now())

  pedidos Pedido[]
  rubros  Rubro[]
  acopios Acopio[]
}

model Rubro {
  id            String   @id @default(cuid())
  nombre        String   @unique
  // Prefijo (2-4 letras) usado para armar el código de los materiales de
  // este rubro (ej. HIE de "Hierros" -> HIE-001, HIE-002, ...).
  codigoPrefijo String?  @unique
  orden         Int      @default(0)
  createdAt     DateTime @default(now())

  proveedores Proveedor[]
  materiales  Material[]
}

model Material {
  id           String   @id @default(cuid())
  // Código corto para identificar el material (ej. HIE-001).
  // Se genera automáticamente al crearlo y se puede editar después.
  codigo       String   @unique
  nombre       String
  unidad       String
  // Peso (en la unidad del material, ej. kg) de una barra/unidad física.
  // Permite convertir automáticamente al registrar una entrega que llega
  // contada en barras aunque el pedido esté cotizado por peso.
  pesoPorBarra Decimal? @db.Decimal(10, 3)
  rubroId      String?
  rubro        Rubro?   @relation(fields: [rubroId], references: [id])
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())

  pedidoItems           PedidoItem[]
  acopios               Acopio[]
  acopioPrecios         AcopioPrecio[]
  movimientosInventario InventarioMovimiento[]
}

model Pedido {
  id          String       @id @default(cuid())
  numero      Int
  proyectoId  String
  proyecto    Proyecto     @relation(fields: [proyectoId], references: [id])
  proveedorId String
  proveedor   Proveedor    @relation(fields: [proveedorId], references: [id])
  acopioId    String?
  acopio      Acopio?      @relation(fields: [acopioId], references: [id])
  fecha       DateTime     @default(now())
  estado      EstadoPedido @default(PENDIENTE)
  notas       String?
  archivoUrl  String?
  creadoPorId String?
  creadoPor   User?        @relation("PedidoCreadoPor", fields: [creadoPorId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items    PedidoItem[]
  entregas Entrega[]

  @@unique([proyectoId, numero])
  @@index([proyectoId])
  @@index([proveedorId])
  @@index([acopioId])
  @@index([estado])
}

model PedidoItem {
  id                String   @id @default(cuid())
  pedidoId          String
  pedido            Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  materialId        String
  material          Material @relation(fields: [materialId], references: [id])
  cantidadPedida    Decimal  @db.Decimal(12, 2)
  unidad            String
  cantidadEntregada Decimal  @default(0) @db.Decimal(12, 2)
  precioUnitario    Decimal? @db.Decimal(12, 2)

  entregaItems EntregaItem[]

  @@index([pedidoId])
  @@index([materialId])
}

model Entrega {
  id              String   @id @default(cuid())
  pedidoId        String
  pedido          Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  fecha           DateTime @default(now())
  numeroRemito    String?
  remitoUrl       String?
  notas           String?
  registradoPorId String?
  registradoPor   User?    @relation("EntregaRegistradaPor", fields: [registradoPorId], references: [id])
  createdAt       DateTime @default(now())

  items                 EntregaItem[]
  movimientosInventario InventarioMovimiento[]

  @@index([pedidoId])
}

model EntregaItem {
  id           String     @id @default(cuid())
  entregaId    String
  entrega      Entrega    @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  pedidoItemId String
  pedidoItem   PedidoItem @relation(fields: [pedidoItemId], references: [id])
  cantidad     Decimal    @db.Decimal(12, 2)

  @@index([entregaId])
  @@index([pedidoItemId])
}

model Acopio {
  id            String     @id @default(cuid())
  proyectoId    String
  proyecto      Proyecto   @relation(fields: [proyectoId], references: [id])
  proveedorId   String
  proveedor     Proveedor  @relation(fields: [proveedorId], references: [id])
  tipo          TipoAcopio
  fecha         DateTime   @default(now())
  notas         String?
  montoTotal    Decimal?   @db.Decimal(12, 2)
  materialId    String?
  material      Material?  @relation(fields: [materialId], references: [id])
  cantidadTotal Decimal?   @db.Decimal(12, 2)
  unidad        String?
  createdAt     DateTime   @default(now())

  precios AcopioPrecio[]
  pedidos Pedido[]

  @@index([proyectoId])
  @@index([proveedorId])
  @@index([materialId])
}

model AcopioPrecio {
  id             String   @id @default(cuid())
  acopioId       String
  acopio         Acopio   @relation(fields: [acopioId], references: [id], onDelete: Cascade)
  materialId     String
  material       Material @relation(fields: [materialId], references: [id])
  precioUnitario Decimal  @db.Decimal(12, 2)

  @@unique([acopioId, materialId])
  @@index([acopioId])
}

model InventarioMovimiento {
  id         String                   @id @default(cuid())
  materialId String
  material   Material                 @relation(fields: [materialId], references: [id])
  tipo       TipoMovimientoInventario
  cantidad   Decimal                  @db.Decimal(12, 2)
  fecha      DateTime                 @default(now())
  notas      String?
  createdAt  DateTime                 @default(now())
  entregaId  String?
  entrega    Entrega?                 @relation(fields: [entregaId], references: [id], onDelete: Cascade)

  @@index([materialId])
  @@index([fecha])
  @@index([entregaId])
}

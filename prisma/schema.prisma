generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EstadoProyecto {
  ACTIVO
  PAUSADO
  FINALIZADO
}

enum EstadoPedido {
  PENDIENTE
  PARCIAL
  COMPLETO
  CANCELADO
}

enum TipoAcopio {
  MONTO
  MATERIAL
}

enum TipoMovimientoInventario {
  ENTRADA
  SALIDA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nombre       String
  esAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  pedidosCreados   Pedido[]  @relation("PedidoCreadoPor")
  entregasCargadas Entrega[] @relation("EntregaRegistradaPor")
}

model Proyecto {
  id          String         @id @default(cuid())
  nombre      String
  direccion   String?
  estado      EstadoProyecto @default(ACTIVO)
  descripcion String?
  imagenUrl   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  pedidos Pedido[]
  acopios Acopio[]
}

model Proveedor {
  id        String   @id @default(cuid())
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  cuit      String?
  notas     String?
  createdAt DateTime @default(now())

  pedidos Pedido[]
  rubros  Rubro[]
  acopios Acopio[]
}

model Rubro {
  id        String   @id @default(cuid())
  nombre    String   @unique
  orden     Int      @default(0)
  createdAt DateTime @default(now())

  proveedores Proveedor[]
  materiales  Material[]
}

model Material {
  id        String   @id @default(cuid())
  nombre    String
  unidad    String
  rubroId   String?
  rubro     Rubro?   @relation(fields: [rubroId], references: [id])
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  pedidoItems           PedidoItem[]
  acopios               Acopio[]
  acopioPrecios         AcopioPrecio[]
  movimientosInventario InventarioMovimiento[]
}

model Pedido {
  id          String       @id @default(cuid())
  numero      Int
  proyectoId  String
  proyecto    Proyecto     @relation(fields: [proyectoId], references: [id])
  proveedorId String
  proveedor   Proveedor    @relation(fields: [proveedorId], references: [id])
  acopioId    String?
  acopio      Acopio?      @relation(fields: [acopioId], references: [id])
  fecha       DateTime     @default(now())
  estado      EstadoPedido @default(PENDIENTE)
  notas       String?
  creadoPorId String?
  creadoPor   User?        @relation("PedidoCreadoPor", fields: [creadoPorId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items    PedidoItem[]
  entregas Entrega[]

  @@unique([proyectoId, numero])
  @@index([proyectoId])
  @@index([proveedorId])
  @@index([acopioId])
  @@index([estado])
}

model PedidoItem {
  id                String   @id @default(cuid())
  pedidoId          String
  pedido            Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  materialId        String
  material          Material @relation(fields: [materialId], references: [id])
  cantidadPedida    Decimal  @db.Decimal(12, 2)
  unidad            String
  cantidadEntregada Decimal  @default(0) @db.Decimal(12, 2)
  precioUnitario    Decimal? @db.Decimal(12, 2)

  entregaItems EntregaItem[]

  @@index([pedidoId])
  @@index([materialId])
}

model Entrega {
  id              String   @id @default(cuid())
  pedidoId        String
  pedido          Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  fecha           DateTime @default(now())
  numeroRemito    String?
  remitoUrl       String?
  notas           String?
  registradoPorId String?
  registradoPor   User?    @relation("EntregaRegistradaPor", fields: [registradoPorId], references: [id])
  createdAt       DateTime @default(now())

  items                 EntregaItem[]
  movimientosInventario InventarioMovimiento[]

  @@index([pedidoId])
}

model EntregaItem {
  id           String     @id @default(cuid())
  entregaId    String
  entrega      Entrega    @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  pedidoItemId String
  pedidoItem   PedidoItem @relation(fields: [pedidoItemId], references: [id])
  cantidad     Decimal    @db.Decimal(12, 2)

  @@index([entregaId])
  @@index([pedidoItemId])
}

model Acopio {
  id            String     @id @default(cuid())
  proyectoId    String
  proyecto      Proyecto   @relation(fields: [proyectoId], references: [id])
  proveedorId   String
  proveedor     Proveedor  @relation(fields: [proveedorId], references: [id])
  tipo          TipoAcopio
  fecha         DateTime   @default(now())
  notas         String?
  montoTotal    Decimal?   @db.Decimal(12, 2)
  materialId    String?
  material      Material?  @relation(fields: [materialId], references: [id])
  cantidadTotal Decimal?   @db.Decimal(12, 2)
  unidad        String?
  createdAt     DateTime   @default(now())

  precios AcopioPrecio[]
  pedidos Pedido[]

  @@index([proyectoId])
  @@index([proveedorId])
  @@index([materialId])
}

model AcopioPrecio {
  id             String   @id @default(cuid())
  acopioId       String
  acopio         Acopio   @relation(fields: [acopioId], references: [id], onDelete: Cascade)
  materialId     String
  material       Material @relation(fields: [materialId], references: [id])
  precioUnitario Decimal  @db.Decimal(12, 2)

  @@unique([acopioId, materialId])
  @@index([acopioId])
}

model InventarioMovimiento {
  id         String                   @id @default(cuid())
  materialId String
  material   Material                 @relation(fields: [materialId], references: [id])
  tipo       TipoMovimientoInventario
  cantidad   Decimal                  @db.Decimal(12, 2)
  fecha      DateTime                 @default(now())
  notas      String?
  createdAt  DateTime                 @default(now())
  entregaId  String?
  entrega    Entrega?                 @relation(fields: [entregaId], references: [id], onDelete: Cascade)

  @@index([materialId])
  @@index([fecha])
  @@index([entregaId])
}
